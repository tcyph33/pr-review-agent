# Copy this file to .env and fill in your values.
# Optional — you can also set these as environment variables directly.

GITHUB_API_TOKEN=ghp_yourTokenHere

# REVIEW REPOS.
# A repo can appear in both lists — both checks will apply
# Repos to watch for review-requested (comma separated, format: owner/repo)
REVIEW_REQUESTED_REPOS=org/repo1,org/repo2
# Repos to watch for assignee (comma separated, format: owner/repo)
REVIEW_ASSIGNEE_REPOS=org/special-repo

# Must be a GitHub API URL (not a raw.githubusercontent.com URL)
# Format: https://api.github.com/repos/<owner>/<repo>/contents/<path-to-skill>.md
# Note: if your repo is in an org with SAML SSO, authorize your token for that org at
#       github.com → Settings → Developer settings → Personal access tokens → Configure SSO
REVIEW_SKILL_URL=https://api.github.com/repos/tcyph33/claude-toolkit/contents/skills/code-review/SKILL.md
