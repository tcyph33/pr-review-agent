# Copy this file to .env and fill in your values.
# Optional — you can also set these as environment variables directly.

# Required on macOS with Node 24 to use system keychain certificates
NODE_USE_SYSTEM_CA=1

GITHUB_API_TOKEN=ghp_yourTokenHere

# Must be a GitHub API URL (not a raw.githubusercontent.com URL)
# Format: https://api.github.com/repos/<owner>/<repo>/contents/<path-to-skill>.md
# Note: if your repo is in an org with SAML SSO, authorize your token for that org at
#       github.com → Settings → Developer settings → Personal access tokens → Configure SSO
REVIEW_SKILL_URL=https://raw.githubusercontent.com/tcyph33/claude-toolkit/refs/heads/main/skills/code-review/SKILL.md
